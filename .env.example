# ──────────────────────────────────────────────
# AI WAF Middleware — Environment Variables
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# [REQUIRED] Groq API key — https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# Groq model to use for classification
# Recommended  : llama-3.3-70b-versatile  (fast + accurate)
# Fastest       : llama3-8b-8192
# Alternative   : mixtral-8x7b-32768
GROQ_MODEL=llama-3.3-70b-versatile

# Middleware operating mode:
#   block  — return 403 Forbidden when threat score >= BLOCK_THRESHOLD
#   detect — log & tag header, always forward to backend
WAF_MODE=block

# Score threshold (0-100) above which action = "block"
BLOCK_THRESHOLD=70
